# ==========================================
# Dracin Environment Configuration
# Copy this file to .env and update values
# ==========================================

# Domain Configuration
DOMAIN=your-domain.com
PUBLIC_URL=https://your-domain.com

# API Configuration
# Primary API - Main API Document (required)
PRIMARY_API_URL=https://api.primary.url

# Backup API - Secondary/Failover API (optional)
BACKUP_API_URL=https://api.backup.url

# Service Description
DESCRIPTION=Dracin API Proxy - Drama streaming with Primary/Backup API failover
