# ==========================================
# Dracin Environment Configuration
# Copy this file to .env and update values
# ==========================================

# Domain Configuration
DOMAIN=your-domain.com
PUBLIC_URL=https://your-domain.com

# API Configuration
# Primary API - Main API Document
PRIMARY_API_URL=https://api.sansekai.my.id/api/dramabox

# Backup API - Secondary/Failover API
BACKUP_API_URL=https://apihub.bzbeez.work/api/dramabox

# Current API - Defaults to primary
API_URL=https://api.sansekai.my.id/api/dramabox

# Service Description
DESCRIPTION=Dracin API Proxy - Drama streaming with Primary/Backup API failover
